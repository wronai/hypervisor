{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://uri3.io/schemas/log_event.schema.json",
  "title": "LogEvent",
  "type": "object",
  "required": ["apiVersion", "kind", "timestamp", "level", "event"],
  "properties": {
    "$schema": { "type": "string" },
    "apiVersion": { "const": "uri3.io/v1" },
    "kind": { "const": "LogEvent" },
    "timestamp": { "type": "string" },
    "level": {
      "type": "string",
      "enum": ["DEBUG", "INFO", "WARNING", "ERROR", "CRITICAL"]
    },
    "logger": { "type": "string" },
    "message": { "type": "string" },
    "uri": {
      "type": "object",
      "properties": {
        "self": { "type": "string", "pattern": "^log://" },
        "subject": { "type": "string" }
      },
      "additionalProperties": true
    },
    "event": {
      "type": "object",
      "required": ["code", "message"],
      "properties": {
        "code": { "type": "string" },
        "message": { "type": "string" }
      },
      "additionalProperties": true
    },
    "correlation": {
      "type": "object",
      "properties": {
        "workflow_id": { "type": "string" },
        "step_id": { "type": "string" },
        "incident_id": { "type": "string" },
        "ticket_id": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
