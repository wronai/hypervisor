{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://uri3.io/schemas/incident.schema.json",
  "title": "IncidentArtifact",
  "type": "object",
  "required": [
    "$schema",
    "apiVersion",
    "kind",
    "metadata",
    "uri",
    "status",
    "symptoms",
    "evidence"
  ],
  "additionalProperties": true,
  "properties": {
    "$schema": { "type": "string" },
    "apiVersion": { "const": "uri3.io/v1" },
    "kind": { "const": "Incident" },
    "metadata": {
      "type": "object",
      "required": ["id", "created_at", "created_by", "source"],
      "properties": {
        "id": { "type": "string", "pattern": "^inc_" },
        "created_at": { "type": "string" },
        "created_by": { "type": "string" },
        "source": { "type": "string" },
        "agent_id": { "type": "string" }
      }
    },
    "uri": {
      "type": "object",
      "required": ["self", "subject"],
      "properties": {
        "self": { "type": "string", "pattern": "^incident://" },
        "subject": { "type": "string" },
        "deployment": { "type": "string" },
        "runtime_state": { "type": "string" },
        "health": { "type": "string" },
        "logs": { "type": "string" }
      }
    },
    "status": {
      "type": "object",
      "required": ["lifecycle_status", "health_status", "service_result_status"],
      "properties": {
        "lifecycle_status": { "type": "string" },
        "health_status": { "type": "string" },
        "workflow_status": { "type": "string" },
        "execution_status": { "type": "string" },
        "service_result_status": { "type": "string" }
      }
    },
    "symptoms": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["code", "message", "severity"],
        "properties": {
          "code": { "type": "string" },
          "message": { "type": "string" },
          "severity": { "enum": ["info", "warning", "error", "critical"] }
        }
      }
    },
    "evidence": { "type": "object" },
    "classification": { "type": "object" },
    "repair": { "type": "object" },
    "evolution": { "type": "object" },
    "result": { "type": "object" }
  }
}
