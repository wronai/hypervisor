{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Command Contract",
  "type": "object",
  "required": [
    "commands"
  ],
  "properties": {
    "commands": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "uri",
          "handler_uri"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "uri": {
            "type": "string",
            "pattern": "^command://"
          },
          "handler_uri": {
            "type": "string",
            "pattern": "^python://"
          },
          "input_schema_ref": {
            "type": "string"
          },
          "emits": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}